# ─────────────────────────────────────────
# FlutterMind — .gitignore
# ─────────────────────────────────────────

# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.iml
*.log

# Android
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
**/*.keystore
**/*.jks

# iOS (excluded from this project but added for safety)
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/DerivedData/
**/ios/**/xcuserdata/
**/ios/.generated/
**/ios/Flutter/.last_build_id

# VS Code
.vscode/
*.code-workspace

# Android Studio / IntelliJ
.idea/
*.iws
*.ipr

# macOS
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# Python (AI training scripts)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
ai/venv/
ai/env/
ai/.env
ai/data/irnd/
ai/data/robot_train.jsonl
ai/data/robot_val.jsonl
ai/data/combined_train.jsonl
*.gguf
*.ggml
*.bin

# Model files (too large for git — use Git LFS or share separately)
*.gguf
*.ggml
*.safetensors
*.pt
*.pth

# Logs
*.log
logs/
ai/runs/

# Secrets
.env
*.pem
google-services.json
GoogleService-Info.plist

# Test outputs
coverage/
lcov.info